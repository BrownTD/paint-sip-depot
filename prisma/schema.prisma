generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(HOST)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts Account[]
  events   Event[]
  sessions Session[]
  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Event {
  id          String  @id @default(cuid())
  hostId      String
  title       String
  description String?
  slug        String  @unique
  eventCode   String? @unique

  startDateTime DateTime
  endDateTime   DateTime?

  locationName String
  address      String?
  city         String?
  state        String?
  zip          String?
  visibility   EventVisibility @default(PUBLIC)
  eventFormat  EventFormat     @default(IN_PERSON)

  ticketPriceCents Int
  capacity         Int
  salesCutoffHours Int     @default(48)
  bookingCutoffOverrideAt DateTime?
  refundPolicyText String?

  canvasImageUrl String?
  canvasName     String?
  qrCodeImageUrl String?

  status    EventStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  bookings Booking[]

  host   User    @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@index([hostId])
  @@index([status])
  @@index([startDateTime])
  @@index([visibility, status, startDateTime])
  @@map("events")
}

model ProductCategory {
  id        String   @id
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      Product[]
  subcategories ProductSubcategory[]

  @@index([createdAt])
  @@map("product_categories")
}

model ProductSubcategory {
  id         String   @id
  categoryId String
  name       String
  slug       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@map("product_subcategories")
}

model Product {
  id             String        @id @default(cuid())
  name           String
  normalizedName String        @unique
  sku            String        @unique
  skuSequence    Int
  description    String
  imageUrls      String[]
  priceCents     Int
  discountPercent Int?
  currency       String        @default("usd")
  stripeProductId String?      @unique
  stripePriceId  String?       @unique
  status         ProductStatus @default(ACTIVE)
  archivedAt     DateTime?
  categoryId     String
  subcategoryId  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category    ProductCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory ProductSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)
  colorOptions ProductColorOption[]
  reviews     ProductReview[]
  variants    ProductVariant[]
  orderItems  ShopOrderItem[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@unique([categoryId, skuSequence])
  @@map("products")
}

model ProductColorOption {
  id        String   @id @default(cuid())
  productId String
  label     String
  hex       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems ShopOrderItem[]

  @@unique([productId, label])
  @@index([productId, sortOrder])
  @@map("product_color_options")
}

model ProductVariant {
  id            String             @id @default(cuid())
  productId     String
  size          ProductVariantSize
  sku           String             @unique
  label         String
  widthInches   Int
  heightInches  Int
  priceCents    Int
  currency      String             @default("usd")
  stripePriceId String?            @unique
  isDefault     Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems ShopOrderItem[]

  @@unique([productId, size])
  @@index([productId])
  @@map("product_variants")
}

model ProductReview {
  id               String   @id @default(cuid())
  productId        String
  reviewerName     String
  reviewerEmail    String
  rating           Int
  body             String
  imageUrl         String?
  isVerifiedPurchase Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([productId, rating])
  @@index([reviewerEmail])
  @@map("product_reviews")
}

model ReturnSubmission {
  id          String   @id @default(cuid())
  orderNumber String
  customerName String
  customerEmail String
  phoneNumber String?
  issueType   String
  description String
  photoUrls   String[]
  status      String   @default("SUBMITTED")
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
  @@index([orderNumber])
  @@map("return_submissions")
}

model Booking {
  id String @id @default(cuid())

  eventId                 String
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  reservationExpiresAt    DateTime?

  purchaserName   String
  purchaserEmail  String
  quantity        Int
  amountPaidCents Int

  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  emailLogs BookingEmailLog[]

  @@index([eventId])
  @@index([purchaserEmail])
  @@index([eventId, status, reservationExpiresAt])
  @@map("bookings")
}

model ShopOrder {
  id                    String          @id @default(cuid())
  customerName          String
  customerEmail         String
  currency              String          @default("usd")
  status                ShopOrderStatus @default(PENDING)
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId String?
  amountSubtotalCents   Int
  amountTotalCents      Int
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  items ShopOrderItem[]

  @@index([status, createdAt])
  @@index([customerEmail])
  @@map("shop_orders")
}

model ShopOrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String
  variantId           String?
  colorOptionId       String?
  productNameSnapshot String
  variantLabelSnapshot String
  colorLabelSnapshot  String?
  imageUrlSnapshot    String?
  quantity            Int
  unitPriceCents      Int
  totalPriceCents     Int
  currency            String   @default("usd")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  order   ShopOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  colorOption ProductColorOption? @relation(fields: [colorOptionId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([colorOptionId])
  @@map("shop_order_items")
}

model BookingEmailLog {
  id                String             @id @default(cuid())
  bookingId         String
  emailType         BookingEmailType
  status            BookingEmailStatus
  recipientEmail    String
  provider          String
  providerMessageId String?
  attemptedAt       DateTime           @default(now())
  sentAt            DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, emailType])
  @@index([bookingId, emailType, status])
  @@map("booking_email_logs")
}

enum UserRole {
  HOST
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ENDED
  CANCELED
}

enum BookingStatus {
  PENDING
  RESERVED
  PAID
  REFUNDED
  EXPIRED
  CANCELED
}

enum BookingEmailType {
  EXPIRED_CHECKOUT
}

enum BookingEmailStatus {
  PENDING
  SENT
  FAILED
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum ProductVariantSize {
  MEDIUM
  LARGE
}

enum ShopOrderStatus {
  PENDING
  PAID
  REFUNDED
  CANCELED
  EXPIRED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventFormat {
  IN_PERSON
  VIRTUAL
}
